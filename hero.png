@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  * { box-sizing: border-box; }
  html, body, #root {
    height: 100%;
    margin: 0;
    padding: 0;
    overflow: hidden;
  }
  body {
    background-color: #070b14;
    background-image:
      radial-gradient(ellipse at 20% 50%, rgba(99, 102, 241, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(16, 185, 129, 0.04) 0%, transparent 40%),
      radial-gradient(ellipse at 60% 80%, rgba(239, 68, 68, 0.04) 0%, transparent 40%);
    color: #e2e8f0;
    font-family: 'Space Grotesk', sans-serif;
  }
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: #0d1420; }
  ::-webkit-scrollbar-thumb { background: #1e3a5f; border-radius: 2px; }
}

@layer components {
  .card-shadow {
    box-shadow:
      0 25px 60px rgba(0,0,0,0.7),
      0 0 0 1px rgba(30, 58, 95, 0.5),
      inset 0 1px 0 rgba(255,255,255,0.05);
  }
  .faction-glow-senate { box-shadow: 0 0 20px rgba(99, 102, 241, 0.4); }
  .faction-glow-military { box-shadow: 0 0 20px rgba(239, 68, 68, 0.4); }
  .faction-glow-trade { box-shadow: 0 0 20px rgba(245, 158, 11, 0.4); }
  .faction-glow-coalition { box-shadow: 0 0 20px rgba(16, 185, 129, 0.4); }

  .swipe-hint-left {
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .swipe-hint-right {
    opacity: 0;
    transition: opacity 0.15s ease;
  }
}
